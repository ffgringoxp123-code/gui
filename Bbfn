local function GetCurveCFrame()
	local currentCamera = workspace.CurrentCamera
	local character = LocalPlayer.Character
	local HumanoidRootPart = character and character:FindFirstChild("HumanoidRootPart") 
	
	if not HumanoidRootPart then
		return currentCamera.CFrame
	end
	
	local highestDot = -math.huge
	local targetPos = nil
	
	if Alive then
		for _, playerChar in pairs(Alive:GetChildren()) do
			if (playerChar ~= character) and playerChar:FindFirstChild("HumanoidRootPart") then
				local dir = (playerChar.HumanoidRootPart.Position - currentCamera.CFrame.Position).Unit
				local dot = currentCamera.CFrame.LookVector:Dot(dir)
				if dot > highestDot then
					highestDot = dot
					targetPos = playerChar.HumanoidRootPart.Position
				end
			end
		end
	end
	
	targetPos = targetPos or (HumanoidRootPart.Position + (currentCamera.CFrame.LookVector * 1000)) 
	local dirToTarget = (targetPos - HumanoidRootPart.Position).Unit
	
	if CurveMethod == "dot" then
		return CFrame.lookAt(HumanoidRootPart.Position, dirToTarget + Vector3.new(0, 1.75, 0))
	elseif CurveMethod == "backwards" then
		return CFrame.new(HumanoidRootPart.Position, HumanoidRootPart.Position + (-dirToTarget * 1000))
	elseif CurveMethod == "slow" then
		return CFrame.new(HumanoidRootPart.Position, HumanoidRootPart.Position + Vector3.new(0, -350, 0))
	else
		return currentCamera.CFrame
	end
end

local Shared = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("SwordAPI")
local LastAnimTick = 0 
local AnimFlag = false
local AnimCache = {}
local CurrentParryAnim = nil

local function GetCharacter()
	return LocalPlayer.Character
end

local function GetHumanoid()
	local char = GetCharacter()
	return char and char:FindFirstChildOfClass("Humanoid") 
end

local function StopAnim(animTrack)
	animTrack:Stop(animTrack:GetAttribute("StopFadeTime") or 0.1)
end

local function PlayAnim(animTrack)
	animTrack:Play(animTrack:GetAttribute("PlayFadeTime") or 0, animTrack:GetAttribute("PlayWeight") or 1, animTrack:GetAttribute("PlaySpeed") or 1)
end

local function GetSwordAnimation()
	local char = GetCharacter()
	if not char then return nil end
	
	local equippedSword = char:GetAttribute("CurrentlyEquippedSword")
	if not equippedSword then return Shared.Collection.Default:FindFirstChild("GrabParry") end
	
	if AnimCache[equippedSword] then return AnimCache[equippedSword] end
	
	local success, result = pcall(function()
		return ReplicatedStorage.Shared.ReplicatedInstances.Swords.GetSword:Invoke(equippedSword)
	end)
	
	if not success or type(result) ~= "table" then
		AnimCache[equippedSword] = Shared.Collection.Default:FindFirstChild("GrabParry")
		return AnimCache[equippedSword]
	end
	
	for _, anim in pairs(Shared.Collection:GetChildren()) do
		if anim.Name == result.AnimationType then
			local GrabParry = anim:FindFirstChild("GrabParry") or anim:FindFirstChild("Grab") 
			if GrabParry then
				AnimCache[equippedSword] = GrabParry
				return GrabParry
			end
		end
	end
	
	AnimCache[equippedSword] = Shared.Collection.Default:FindFirstChild("GrabParry")
	return AnimCache[equippedSword]
end

local function HandleParryAnimation()
	local hum = GetHumanoid()
	if not hum then return end
	
	local swordAnim = GetSwordAnimation()
	if not swordAnim then return end
	
	for _, track in pairs(hum.Animator:GetPlayingAnimationTracks()) do
		if track.Name == "GrabParry" or track.Name == "Grab" then
			track.TimePosition = 0 
			StopAnim(track)
		elseif track.Name == "SuccessParry" or track.Name == "Success" then
			StopAnim(track)
		end
	end
	
	CurrentParryAnim = hum.Animator:LoadAnimation(swordAnim)
	PlayAnim(CurrentParryAnim)
end

local function ExecuteAnimFix()
	if (os.clock() - LastAnimTick) >= 0.2 or AnimFlag then
		LastAnimTick = os.clock()
		AnimFlag = false
		HandleParryAnimation()
	end
end

pcall(function()
	ReplicatedStorage.Remotes.ParrySuccess.OnClientEvent:Connect(function()
		AnimFlag = true
		local hum = GetHumanoid()
		if hum then
			for _, track in pairs(hum.Animator:GetPlayingAnimationTracks()) do
				if track.Name == "GrabParry" or track.Name == "Grab" then
					StopAnim(track)
				end
			end
		end
	end)
end)

local function ToggleHeadless(char, state)
	if not char then return end
	local head = char:FindFirstChild("Head")
	
	if head then
		head.Transparency = state and 1 or 0 
		for _, obj in pairs(head:GetChildren()) do
			if obj:IsA("Decal") or obj:IsA("SpecialMesh") then
				obj.Transparency = state and 1 or 0 
			end
		end
	end
	
	for _, obj in pairs(char:GetChildren()) do
		if obj:IsA("Accessory") then
			local handle = obj:FindFirstChild("Handle")
			if handle then
				local attachment = handle:FindFirstChild("HatAttachment") or handle:FindFirstChild("HairAttachment") or handle:FindFirstChild("FaceFrontAttachment") or handle:FindFirstChild("FaceBackAttachment") or handle:FindFirstChild("NeckAttachment") 
				if attachment then
					handle.Transparency = state and 1 or 0 
				end
			end
		end
	end
end

