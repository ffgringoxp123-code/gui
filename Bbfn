local LastBallCheckTick = 0
local CurrentTargetBall = nil

local SavedQuality = nil
local function SetLowRender(state)
	if state then
		pcall(function()
			SavedQuality = settings().Rendering.QualityLevel
			settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
			game:GetService("Lighting").GlobalShadows = false
			game:GetService("Lighting").FogEnd = 8999999488
		end)
	else
		pcall(function()
			if SavedQuality then
				settings().Rendering.QualityLevel = SavedQuality
			end
			game:GetService("Lighting").GlobalShadows = true
		end)
	end
end

RunService.Heartbeat:Connect(function()
	local t = tick()
	
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart") 
	if not hrp then return end
	
	if (t - LastBallCheckTick) > 1 then
		CurrentTargetBall = GetBall()
		LastBallCheckTick = t
	end
	
	local ball = CurrentTargetBall
	local isAlive = IsAlive()
	
	if ball and ball:IsA("BasePart") then
		local ballSpeed = ball.Velocity.Magnitude
		
		local pingSec = 0.08
		pcall(function() pingSec = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
		
		local dist = (hrp.Position - ball.Position).Magnitude
		local targetAtt = ball:GetAttribute("target") or ball:GetAttribute("Target") or ball:GetAttribute("targetPlayer") or ball:GetAttribute("TargetPlayer") 
		local isTargetingMe = (targetAtt == LocalPlayer.Name) or (targetAtt == LocalPlayer.UserId) or (targetAtt == tostring(LocalPlayer.UserId)) 
	
		if Config.AutoParry and ParryRemote and FireServerFunc and isTargetingMe then
			local ignoreAbility = (Detections.infinity and AbilityActive.Infinity) or (Detections.deathslash and AbilityActive.DeathSlash) or (Detections.timehole and AbilityActive.TimeHole) 
			
			if not ignoreAbility then
				local debugId = ball:GetDebugId()
				if not IgnoreParryList[debugId] then
					local shouldParry = false
					local zoomies = ball:FindFirstChild("zoomies")
					
					if zoomies then
						local dirToMe = (hrp.Position - ball.Position).Unit
						local dotP = dirToMe:Dot(zoomies.VectorVelocity.Unit)
						if dotP >= (0.3 - (pingSec * 0.5)) then
							local dynamicThreshold = ballSpeed * (pingSec + 0.016) * 8 * 0.43 
							if dist <= dynamicThreshold or dist <= 9 then
								shouldParry = true
							end
						end
					elseif dist <= 12 and ballSpeed > 1 then
						shouldParry = true
					end
					
					if shouldParry and Config.CooldownProtect then
						pcall(function()
							local uiGrad = LocalPlayer.PlayerGui.Hotbar.Block.UIGradient
							if uiGrad.Offset.Y < 0.4 then
								ReplicatedStorage.Remotes.AbilityButtonPress:Fire()
								shouldParry = false
							end
						end)
					end
					
					if shouldParry then
						AttemptParry()
						IgnoreParryList[debugId] = true
						task.spawn(function()
							ball:GetAttributeChangedSignal("target"):Wait()
							IgnoreParryList[debugId] = nil
						end)
					end
				end
			end
		end
	end
end)
