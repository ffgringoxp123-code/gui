local function GetBall()
	local ballsFolder = workspace:FindFirstChild("Balls")
	if ballsFolder then
		for _, ball in pairs(ballsFolder:GetChildren()) do
			if ball:IsA("BasePart") and ball:GetAttribute("realBall") then
				return ball
			end
		end
		local firstChild = ballsFolder:GetChildren()[1]
		if firstChild and firstChild:IsA("BasePart") then
			return firstChild
		end
	end
	
	for _, obj in ipairs(workspace:GetChildren()) do
		if obj:IsA("BasePart") and obj.Name:lower():find("ball") then
			return obj
		end
	end
	
	for _, folderName in ipairs({"Lobby", "Training", "Practice", "Map", "Game"}) do
		local f = workspace:FindFirstChild(folderName)
		if f then
			for _, obj in ipairs(f:GetDescendants()) do
				if obj:IsA("BasePart") and obj.Name:lower():find("ball") then
					return obj
				end
			end
		end
	end
	return nil
end

local PlayerScreenPositions = {}
local LastScreenPosUpdate = 0 

local function AttemptParry()
	if not (ParryRemote and FireServerFunc) then return end
	
	local currentCamera = workspace.CurrentCamera
	local char = LocalPlayer.Character
	if not char then return end
	
	local t = tick()
	if (t - LastScreenPosUpdate) > 0.1 then
		PlayerScreenPositions = {}
		if Alive then
			for _, p in ipairs(Alive:GetChildren()) do
				if p ~= char and p.PrimaryPart then
					local pos, onScreen = currentCamera:WorldToScreenPoint(p.PrimaryPart.Position)
					if onScreen then
						PlayerScreenPositions[tostring(p)] = pos
					end
				end
			end
		end
		LastScreenPosUpdate = t
	end
	
	local vpSize = currentCamera.ViewportSize
	local curveCFrame = GetCurveCFrame()
	
	RemoteArgs[3] = curveCFrame.LookVector
	RemoteArgs[4] = curveCFrame
	RemoteArgs[5] = PlayerScreenPositions
	RemoteArgs[6] = {vpSize.X / 2, vpSize.Y / 2}
	
	pcall(function()
		FireServerFunc(ParryRemote, unpack(RemoteArgs))
	end)
	
	if Config.AnimationFix then
		task.spawn(ExecuteAnimFix)
	end
end

