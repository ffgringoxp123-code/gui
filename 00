local Visuals = { Enabled = false, HitEffects = false, Tracers = false, Outline = false, VisualParts = {}, TracerLines = {}, OutlineHandles = {}, Color = Color3.fromRGB(255, 255, 255) }

local function FetchBalls()
    local balls = {}
    for _, b in ipairs(BallsFolder:GetChildren()) do if b:GetAttribute("realBall") then table.insert(balls, b) end end
    return balls
end

local function UpdateVisualizer()
    if not Visuals.Enabled then
        for _, part in pairs(Visuals.VisualParts) do
        pcall(function() part:Destroy() end)
    end
    Visuals.VisualParts = {}
    return
end
    for _, ball in ipairs(FetchBalls()) do
        if ball and ball.Parent then
            local speed = ball.AssemblyLinearVelocity.Magnitude
            local size = math.clamp(speed / 5, 3.5, 500)
            if not Visuals.VisualParts[ball] then
                local sphere = Instance.new("Part")
                sphere.Name = "VisualPart"; sphere.Anchored = true; sphere.CanCollide = false; sphere.CastShadow = false
                sphere.Shape = Enum.PartType.Ball; sphere.Transparency = 0; sphere.Material = Enum.Material.ForceField
                sphere.Color = Visuals.Color; sphere.Parent = ball
                Visuals.VisualParts[ball] = sphere
            end
            Visuals.VisualParts[ball].Position = ball.Position
            Visuals.VisualParts[ball].Size = Vector3.new(size, size, size)
            Visuals.VisualParts[ball].Color = Visuals.Color
        end
    end
    for ball, part in pairs(Visuals.VisualParts) do
        if not ball or not ball.Parent then
            pcall(function() part:Destroy() end)
            Visuals.VisualParts[ball] = nil
        end
    end
end

local function UpdateTracers()
    if not Visuals.Tracers then
        for _, line in pairs(Visuals.TracerLines) do pcall(function() line:Destroy() end) end
        Visuals.TracerLines = {}
        return
    end
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, ball in ipairs(FetchBalls()) do
        if ball and ball.Parent then
            if not Visuals.TracerLines[ball] then
                local line = Instance.new("Part")
                line.Name = "Tracer"; line.Anchored = true; line.CanCollide = false; line.CastShadow = false
                line.Material = Enum.Material.Neon; line.Size = Vector3.new(0.2, 0.2, 0)
                line.Color = Visuals.Color; line.Parent = workspace
                Visuals.TracerLines[ball] = line
            end
            local start = ball.Position
            local finish = root.Position
            local dir = (finish - start).Unit
            local dist = (finish - start).Magnitude
            local line = Visuals.TracerLines[ball]
            line.Size = Vector3.new(0.2, 0.2, dist)
            line.CFrame = CFrame.new(start + dir * dist / 2, finish)
            line.Color = Visuals.Color
        end
    end
    for ball, line in pairs(Visuals.TracerLines) do
        if not ball or not ball.Parent then pcall(function() line:Destroy() end); Visuals.TracerLines[ball] = nil end
    end
end

local function UpdateOutline()
    if not Visuals.Outline then
        for _, handle in pairs(Visuals.OutlineHandles) do pcall(function() handle:Destroy() end) end
        Visuals.OutlineHandles = {}
        return
    end
    for _, ball in ipairs(FetchBalls()) do
        if ball and ball.Parent then
            if not Visuals.OutlineHandles[ball] then
