RunService.Heartbeat:Connect(function()
    if Immortality.Enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local rootPart = LocalPlayer.Character.HumanoidRootPart
        currentDesyncRotation = (currentDesyncRotation + 15) % 360
        desyncCFramePositions[1] = rootPart.CFrame
        desyncCFramePositions[2] = rootPart.AssemblyLinearVelocity
        local desyncForce = 3000
        local spoofedCF = rootPart.CFrame * CFrame.Angles(0, math.rad(currentDesyncRotation), 0) + Vector3.new(0, Immortality.DesyncHeight, 0)
        local hWave = math.sin(tick() * 30) * Immortality.DesyncRadius
        local vWave = math.cos(tick() * 60) * Immortality.DesyncHeight
        spoofedCF = spoofedCF * CFrame.new(hWave, vWave, 0) * CFrame.Angles(
            math.rad(GenerateRandomVector(desyncForce)),
            math.rad(GenerateRandomVector(desyncForce)),
            0
        )
        rootPart.CFrame = spoofedCF
        rootPart.AssemblyLinearVelocity = desyncCFramePositions[2] + Vector3.new(
            math.cos(tick() * 8) * desyncForce,
            math.cos(tick() * 8) * desyncForce,
            0
        )
        RunService.RenderStepped:Wait()
        rootPart.CFrame = desyncCFramePositions[1]
        rootPart.AssemblyLinearVelocity = desyncCFramePositions[2]
    end
end)

