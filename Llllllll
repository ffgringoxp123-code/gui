UserInputService.InputBegan:Connect(function(input, gp)
    if gp or waitingForKey then return end
    if input.KeyCode == keyAutoParry then
        AutoParry = not AutoParry
        parried_balls = {}
        notify("Kittylol", "Auto Parry: " .. (AutoParry and "ON" or "OFF"))
    elseif input.KeyCode == keyShowPeak then
        ShowPeak = not ShowPeak
        PFrame.Visible = ShowPeak
    elseif input.KeyCode == keySpam then
        if ManualSpam then
            spamActive = not spamActive
            SpamToggle.Text = "SPAM: " .. (spamActive and "ON" or "OFF")
            SpamToggle.BackgroundColor3 = spamActive and RedBorder or RedDark
        end
    elseif input.KeyCode == keyAutoSpamParry then
        AutoSpamParry = not AutoSpamParry
        getgenv().animationfix = AutoSpamParry
        notify("Kittylol", "Auto Spam Parry: " .. (AutoSpamParry and "ON" or "OFF"))
    elseif input.KeyCode == Enum.KeyCode.X then
        getgenv().AbilityESP = not getgenv().AbilityESP
        for _, label in pairs(billboardLabels) do if label then label.Visible = getgenv().AbilityESP end end
        notify("Kittylol", "Ability ESP: " .. (getgenv().AbilityESP and "ON" or "OFF"))
    end
end)

