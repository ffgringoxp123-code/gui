local PlasmaTrails = {
    Enabled = false,
    NumTrails = 10,
    TrailColor = Color3.fromRGB(255, 105, 180),
    RainbowTrail = false,
    RainbowSpeed = 0.5
}

_G.RainbowTrailLoop = nil
_G.lastTrailRainbowUpdate = nil
_G.rainbowTrailSpeed = 0.5

local Plasma = {
    trail_containers = {},
    trail_parts = {}
}

function Plasma.cleanup_trails(ball)
    if not ball then return end
    local container = Plasma.trail_containers[ball]
    if container then
        for _, part in ipairs(container:GetChildren()) do
            if part:IsA("Part") or part:IsA("Attachment") then
                part:Destroy()
            end
        end
        container:Destroy()
        Plasma.trail_containers[ball] = nil
    end
    Plasma.trail_parts[ball] = nil
end

function Plasma.create_trails(ball)
    if not ball then return end
    Plasma.cleanup_trails(ball)

    local container = Instance.new("Folder")
    container.Name = "BallTrails_" .. ball.Name
    container.Parent = ball
    Plasma.trail_containers[ball] = container

    local trailParts = {}
    for i = 1, PlasmaTrails.NumTrails do
        local trail = Instance.new("Part")
        trail.Size = Vector3.new(0.5, 0.5, 0.5)
        trail.Shape = Enum.PartType.Ball
        trail.Material = Enum.Material.Neon
        trail.Color = PlasmaTrails.TrailColor
        trail.Transparency = 0.2 + (i / PlasmaTrails.NumTrails) * 0.6
        trail.Anchored = true
        trail.CanCollide = false
        trail.Parent = container

        local att = Instance.new("Attachment", trail)
        att.Name = "BallAttach"

        table.insert(trailParts, {
            part = trail,
            offset = i * 0.3
        })
    end
    Plasma.trail_parts[ball] = trailParts
end

function Plasma.update_trail_colors(ball)
    if not ball or not Plasma.trail_parts[ball] then return end
    for _, tp in ipairs(Plasma.trail_parts[ball]) do
        tp.part.Color = PlasmaTrails.TrailColor
    end
end

local trailConnection = RunService.Heartbeat:Connect(function()
    if not PlasmaTrails.Enabled then return end
    local ballContainer = workspace:FindFirstChild("Balls")
    local ball = ballContainer and ballContainer:GetChildren()[1]

    if ball and ball:IsA("BasePart") then
        if ball ~= last_ball then
            if last_ball then
                Plasma.cleanup_trails(last_ball)
            end
            last_ball = ball
            Plasma.create_trails(ball)
        end

        local trailParts = Plasma.trail_parts[ball]
        if trailParts then
            local vel = ball.Velocity
            local pos = ball.Position

            for _, tp in ipairs(trailParts) do
                local targetPos = pos - (vel * tp.offset)
                tp.part.CFrame = CFrame.new(targetPos)
            end
        end
