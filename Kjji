-- ===================== REMOTE HOOK =====================
local remote, f_raw = nil, nil
local c = {nil, nil, nil, nil, nil, nil, nil}
local remoteHooked = false

local mt = getrawmetatable(game)
local old_idx = mt.__index
setreadonly(mt, false)
mt.__index = newcclosure(function(self, key)
    if key == "FireServer" or key == "InvokeServer" then
        return function(instance, ...)
            local args = {...}
            if #args >= 4 and not remoteHooked then
                remoteHooked = true
                remote = instance
                f_raw = old_idx(instance, "FireServer")
                for i = 1, 7 do c[i] = args[i] end
            end
            return old_idx(self, key)(instance, ...)
        end
    end
    return old_idx(self, key)
end)
setreadonly(mt, true)

-- ===================== FIRE PARRY =====================
local function fireParry()
    if not (remote and f_raw) then return end
    local cam = workspace.CurrentCamera
    local char = LocalPlayer.Character
    local viewport = cam.ViewportSize
    local mousePos = {viewport.X / 2, viewport.Y / 2}
    local events = {}
    if workspace:FindFirstChild("Alive") then
        for _, v in ipairs(workspace.Alive:GetChildren()) do
            if v ~= char and v.PrimaryPart then
                local pos, onScreen = cam:WorldToScreenPoint(v.PrimaryPart.Position)
                if onScreen then events[tostring(v)] = pos end
            end
        end
    end
    c[3] = cam.CFrame.LookVector
    c[4] = cam.CFrame
    c[5] = events
    c[6] = mousePos
    pcall(function() f_raw(remote, unpack(c)) end)
end

