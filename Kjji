local function fireParry()
    if not (remote and f_raw) then return end
    local cam = workspace.CurrentCamera; local char = LocalPlayer.Character; local camCF = cam.CFrame; local viewportSize = cam.ViewportSize
    local mousePos = {viewportSize.X/2, viewportSize.Y/2}; local events = {}
    if workspace:FindFirstChild("Alive") then
        for _, v in ipairs(workspace.Alive:GetChildren()) do
            if v ~= char and v.PrimaryPart then
                local screenPos, isOnScreen = cam:WorldToScreenPoint(v.PrimaryPart.Position)
                if isOnScreen then events[tostring(v)] = screenPos end
            end
        end
    end
    c[3] = camCF.LookVector; c[4] = camCF; c[5] = events; c[6] = mousePos
    pcall(function() f_raw(remote, unpack(c)) end)
end

RunService.Heartbeat:Connect(function()
    local ballContainer = workspace:FindFirstChild("Balls"); local ball = ballContainer and ballContainer:GetChildren()[1]
    local char = LocalPlayer.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart"); local cam = workspace.CurrentCamera
    if ball and ball:IsA("BasePart") and hrp then
        local vel = ball.Velocity.Magnitude
        if ShowPeak then
            VLabel.Text = "Cur: "..string.format("%.1f",vel)
            if vel > peakVel then peakVel = vel; PLabel.Text = "Peak: "..string.format("%.1f",peakVel) end
        end
        if AutoParry and remote and f_raw then
            local bID = ball:GetDebugId()
            if not parried_balls[bID] then
                local target = ball:GetAttribute("target") or ball:GetAttribute("Target") or ball:GetAttribute("targetPlayer") or ball:GetAttribute("TargetPlayer")
                local isMyBall = (target == LocalPlayer.Name) or (target == LocalPlayer.UserId) or (target == tostring(LocalPlayer.UserId))
                if isMyBall then
                    local Zoomies = ball:FindFirstChild("zoomies"); local shouldParry = false
                    if Zoomies then
                        local Velocity = Zoomies.VectorVelocity; local Direction = (hrp.Position - ball.Position).Unit; local Dot = Direction:Dot(Velocity.Unit)
                        local Ping = (StatsService.Network.ServerStatsItem["Data Ping"]:GetValue() or 100) / 1000
                        if Dot >= (0.5 - Ping) then
                            local dist = (hrp.Position - ball.Position).Magnitude; local threshold = (Velocity.Magnitude / 3.25) + (Ping * 10)
                            if dist <= threshold or dist <= 15 then shouldParry = true end
                        end
                    else
                        local dist = (hrp.Position - ball.Position).Magnitude; if dist <= 15 then shouldParry = true end
                    end
                    if shouldParry then fireParry(); parried_balls[bID] = true; ball:GetAttributeChangedSignal("target"):Once(function() parried_balls[bID] = nil end) end
                end
            end
        end
    else
        if ShowPeak then VLabel.Text = "Cur: 0.0" end
    end
    if ManualSpam and spamActive and remote and f_raw then
        local now = tick()
        if now - lastSpamTime >= spamInterval then lastSpamTime = now; fireParry() end
    end
end)

