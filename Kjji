-- Desync loop
RunService.Heartbeat:Connect(function()
    if Immortality.Enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character.HumanoidRootPart
        currentDesyncRot = (currentDesyncRot + 15) % 360
        desyncCFrames[1] = root.CFrame
        desyncCFrames[2] = root.AssemblyLinearVelocity
        
        local force = 3000
        local spoofed = root.CFrame * CFrame.Angles(0, math.rad(currentDesyncRot), 0) + Vector3.new(0, Immortality.DesyncHeight, 0)
        local hWave = math.sin(tick() * 30) * Immortality.DesyncRadius
        local vWave = math.cos(tick() * 60) * Immortality.DesyncHeight
        spoofed = spoofed * CFrame.new(hWave, vWave, 0) * CFrame.Angles(
            math.rad(randomVec(force)), math.rad(randomVec(force)), 0
        )
        root.CFrame = spoofed
        root.AssemblyLinearVelocity = desyncCFrames[2] + Vector3.new(
            math.cos(tick() * 8) * force, math.cos(tick() * 8) * force, 0
        )
        RunService.RenderStepped:Wait()
        root.CFrame = desyncCFrames[1]
        root.AssemblyLinearVelocity = desyncCFrames[2]
    end
end)

