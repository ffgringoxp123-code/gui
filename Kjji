-- BALL TRAIL PLASMA
local Plasma = {trail_containers = {}, trail_parts = {}}
function Plasma.cleanup_trails(ball)
    if not ball then return end
    if Plasma.trail_containers[ball] then Plasma.trail_containers[ball]:Destroy(); Plasma.trail_containers[ball] = nil end
    Plasma.trail_parts[ball] = nil
end
function Plasma.create_trails(ball)
    Plasma.cleanup_trails(ball)
    local c = Instance.new("Folder"); c.Name = "Trail_" .. ball.Name; c.Parent = ball
    Plasma.trail_containers[ball] = c
    local parts = {}
    for i = 1, PlasmaTrails.NumTrails do
        local p = Instance.new("Part"); p.Size = Vector3.new(0.5, 0.5, 0.5)
        p.Shape = Enum.PartType.Ball; p.Material = Enum.Material.Neon; p.Color = PlasmaTrails.TrailColor
        p.Transparency = 0.2 + (i / PlasmaTrails.NumTrails) * 0.6; p.Anchored = true; p.CanCollide = false; p.Parent = c
        table.insert(parts, {part = p, offset = i * 0.3})
    end
    Plasma.trail_parts[ball] = parts
end

RunService.Heartbeat:Connect(function()
    if not PlasmaTrails.Enabled then return end
    local bc = workspace:FindFirstChild("Balls"); local ball = bc and bc:GetChildren()[1]
    if ball and ball:IsA("BasePart") then
        if ball ~= last_ball then if last_ball then Plasma.cleanup_trails(last_ball) end; last_ball = ball; Plasma.create_trails(ball) end
        local parts = Plasma.trail_parts[ball]
        if parts then
            local vel = ball.Velocity; local pos = ball.Position
            for _, tp in ipairs(parts) do tp.part.CFrame = CFrame.new(pos - (vel * tp.offset)) end
        end
    elseif last_ball then Plasma.cleanup_trails(last_ball); last_ball = nil end
end)

