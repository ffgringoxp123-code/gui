    if workspace:FindFirstChild("Alive") then for _, v in ipairs(workspace.Alive:GetChildren()) do if v ~= char and v.PrimaryPart then local sp, on = cam:WorldToScreenPoint(v.PrimaryPart.Position); if on then ev[tostring(v)] = sp end end end end
    c[3]=camCF.LookVector; c[4]=camCF; c[5]=ev; c[6]=mp; pcall(function() f_raw(remote, unpack(c)) end)
end

RunService.Heartbeat:Connect(function()
    local bc = workspace:FindFirstChild("Balls"); local ball = bc and bc:GetChildren()[1]; local char = LocalPlayer.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if ball and ball:IsA("BasePart") and hrp then
        local vel = ball.Velocity.Magnitude
        if ShowPeak then
            VLabel.Text = "Cur: "..string.format("%.1f",vel)
            if vel > peakVel then peakVel = vel; PLabel.Text = "Peak: "..string.format("%.1f",peakVel) end
        end
        if AutoParry and remote and f_raw then
            local bid = ball:GetDebugId()
            if not parried_balls[bid] then
                local t = ball:GetAttribute("target") or ball:GetAttribute("Target") or ball:GetAttribute("targetPlayer") or ball:GetAttribute("TargetPlayer")
                local my = (t == LocalPlayer.Name) or (t == LocalPlayer.UserId) or (t == tostring(LocalPlayer.UserId))
                if my then
                    local Z = ball:FindFirstChild("zoomies"); local doP = false
                    if Z then
                        local V = Z.VectorVelocity; local D = (hrp.Position-ball.Position).Unit; local dot = D:Dot(V.Unit)
                        local ping = (StatsService.Network.ServerStatsItem["Data Ping"]:GetValue() or 100)/1000
                        if dot >= (0.5-ping) then local dist = (hrp.Position-ball.Position).Magnitude; local th = (V.Magnitude/3.25)+(ping*10); if dist <= th or dist <= 15 then doP = true end end
                    else local dist = (hrp.Position-ball.Position).Magnitude; if dist <= 15 then doP = true end end
                    if doP then fireParry(); parried_balls[bid] = true; ball:GetAttributeChangedSignal("target"):Once(function() parried_balls[bid] = nil end) end
                end
            end
        end
    elseif ShowPeak then VLabel.Text = "Cur: 0.0" end
    if ManualSpam and spamActive and remote and f_raw then local n = tick(); if n - lastSpamTime >= spamInterval then lastSpamTime = n; fireParry() end end
end)

UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.T then AutoParry = not AutoParry; parried_balls = {}; notify("Kittylol","Auto Parry: "..(AutoParry and "ON" or "OFF"))
    elseif i.KeyCode == Enum.KeyCode.E then ShowPeak = not ShowPeak; PFrame.Visible = ShowPeak
    elseif i.KeyCode == Enum.KeyCode.Q then if ManualSpam then spamActive = not spamActive; SpamToggle.Text = "SPAM: "..(spamActive and "ON" or "OFF"); SpamToggle.BackgroundColor3 = spamActive and RedBorder or RedDark end
    elseif i.KeyCode == Enum.KeyCode.Y then getgenv().animationfix = not getgenv().animationfix; notify("Kittylol","Auto Spam: "..(getgenv().animationfix and "ON" or "OFF"))
    elseif i.KeyCode == Enum.KeyCode.X then getgenv().AbilityESP = not getgenv().AbilityESP; for _, l in pairs(billboardLabels) do if l then l.Visible = getgenv().AbilityESP end end; notify("Kittylol","Ability ESP: "..(getgenv().AbilityESP and "ON" or "OFF")) end
end)

