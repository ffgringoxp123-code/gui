local function fireParry()
    if not (remote and f_raw) then return end
    local cam = workspace.CurrentCamera
    local char = LocalPlayer.Character
    local camCF = cam.CFrame
    local viewportSize = cam.ViewportSize
    local mousePos = {viewportSize.X / 2, viewportSize.Y / 2}
    local events = {}
    if workspace:FindFirstChild("Alive") then
        for _, v in ipairs(workspace.Alive:GetChildren()) do
            if v ~= char and v.PrimaryPart then
                local screenPos, isOnScreen = cam:WorldToScreenPoint(v.PrimaryPart.Position)
                if isOnScreen then events[tostring(v)] = screenPos end
            end
        end
    end
