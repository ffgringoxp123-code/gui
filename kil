local originalMaterials = {}
local originalDecalsTextures = {}
local function applyAntiLag(state)
    if state then
        for _, O in ipairs(workspace:GetDescendants()) do
            if O:IsA("BasePart") and not (O:FindFirstAncestorWhichIsA("Model") and O:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Humanoid")) then
                originalMaterials[O] = O.Material; O.Material = Enum.Material.SmoothPlastic
            elseif O:IsA("Decal") or O:IsA("Texture") then
                table.insert(originalDecalsTextures, {Object = O, Parent = O.Parent}); O.Parent = nil
            elseif O:IsA("ParticleEmitter") or O:IsA("Smoke") or O:IsA("Fire") or O:IsA("Sparkles") then
                O.Enabled = false
            end
        end
    else
        for O, mat in pairs(originalMaterials) do if O and O.Parent then pcall(function() O.Material = mat end) end end
        for _, d in pairs(originalDecalsTextures) do if d.Object and d.Parent then pcall(function() d.Object.Parent = d.Parent end) end end
        originalMaterials = {}; originalDecalsTextures = {}
    end
end

