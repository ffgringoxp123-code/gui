    end
    
    local windowApi={}
    function windowApi:Tab(name, icon)
        local btn=mk("TextButton", {Parent=tabButtons, Size=UDim2.new(1,0,0,32), BackgroundColor3=Theme.Surface2, BorderSizePixel=0, Text="", TextColor3=Theme.Text, Font=Enum.Font.GothamBold, TextSize=13, AutoButtonColor=false})
