-- Override style for active tab
local originalCreateTab = Window.CreateTab
Window.CreateTab = function(self, args)
    local tab = originalCreateTab(self, args)
    task.wait(0.1)
    if tab and tab.TabButton then
        tab.TabButton.BackgroundColor3 = PinkTheme.TabBg
        tab.TabButton.BackgroundColor3 = Color3.fromRGB(255, 105, 180)
    end
    return tab
end

