-- Helper function để đổi màu các phần tử UI
local function ApplyPinkThemeToTab(tab)
    -- Đổi màu tab header
    if tab.TabButton then
        tab.TabButton.BackgroundColor3 = PinkTheme.TabBg
        tab.TabButton.TextColor3 = PinkTheme.TabText
        tab.TabButton.BorderSizePixel = 0
        -- Khi active
        tab.TabButton:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
            -- Giữ màu hồng
        end)
    end
    
    -- Đổi màu sections trong tab
    for _, section in pairs(tab.Sections or {}) do
        if section.Container then
            section.Container.BackgroundColor3 = PinkTheme.SectionBg
            section.Container.BorderColor3 = PinkTheme.SectionBorder
            section.Container.BorderSizePixel = 2
            -- Title của section
            if section.Title then
                section.Title.TextColor3 = PinkTheme.DropdownText
            end
        end
    end
    
    -- Đổi màu các phần tử trong tab
    for _, element in pairs(tab.Elements or {}) do
        if element:IsA("Frame") then
            element.BackgroundColor3 = PinkTheme.SectionBg
        end
    end
end

-- Tạo các tab với màu hồng
local function CreatePinkTab(title, icon)
    local tab = Window:CreateTab({
        Title = title,
        Icon = icon
    })
    
    -- Custom styling cho tab button
    task.wait(0.1)
    if tab.TabButton then
        tab.TabButton.BackgroundColor3 = PinkTheme.TabBg
        tab.TabButton.BackgroundColor3 = Color3.fromRGB(255, 105, 180) -- Pink background for tab
    end
    
    return tab
end

