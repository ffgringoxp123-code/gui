local PinkTheme = {
    TabBg = Color3.fromRGB(255, 105, 180),      -- Màu hồng cho nền tab
    TabText = Color3.fromRGB(255, 255, 255),     -- Chữ trắng
    TabActive = Color3.fromRGB(255, 20, 147),    -- Hồng đậm khi active
    SectionBg = Color3.fromRGB(255, 182, 193),   -- Nền section màu hồng nhạt
    SectionBorder = Color3.fromRGB(255, 105, 180), -- Viền section
    BtnBg = Color3.fromRGB(255, 105, 180),
    BtnText = Color3.fromRGB(255, 255, 255),
    ToggleOn = Color3.fromRGB(255, 20, 147),
    SliderBg = Color3.fromRGB(255, 182, 193),
