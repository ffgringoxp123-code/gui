-- Avatar Changer (phiên bản character tab)
local avatarFlags = {}
CharacterTab:Toggle({ Title = "Avatar Changer", Desc = "Change your avatar to another player", Value = false, Flag = "AvatarChangerToggle",
    Callback = function(v)
        avatarFlags.Active = v
        if v then
            local char = player.Character
            if char and avatarFlags.name then
                local success, err = pcall(function()
                    local uid = Players:GetUserIdFromNameAsync(avatarFlags.name)
                    local desc = Players:GetHumanoidDescriptionFromUserId(uid)
                    if desc then
                        player:ClearCharacterAppearance()
                        char:WaitForChild("Humanoid", 5):ApplyDescriptionClientServer(desc)
                    end
                end)
            end
            if not avatarFlags.loop then
                avatarFlags.loop = player.CharacterAdded:Connect(function(c)
                    task.wait(0.75)
                    if avatarFlags.Active and avatarFlags.name then
                        pcall(function()
                            local uid = Players:GetUserIdFromNameAsync(avatarFlags.name)
                            local desc = Players:GetHumanoidDescriptionFromUserId(uid)
                            if desc then
                                player:ClearCharacterAppearance()
                                c:WaitForChild("Humanoid", 5):ApplyDescriptionClientServer(desc)
                            end
                        end)
                    end
                end)
            end
        else
            if avatarFlags.loop then avatarFlags.loop:Disconnect(); avatarFlags.loop = nil end
            local char = player.Character
            if char then
                pcall(function()
                    local uid = Players:GetUserIdFromNameAsync(player.Name)
                    local desc = Players:GetHumanoidDescriptionFromUserId(uid)
                    if desc then char:WaitForChild("Humanoid", 5):ApplyDescriptionClientServer(desc) end
                end)
            end
        end
    end })
CharacterTab:Input({ Title = "Avatar Username", Desc = "Roblox username to copy appearance from", Value = "", Flag = "AvatarChangerName", Placeholder = "Enter username...",
    Callback = function(v) avatarFlags.name = v end })

