        PLabel.TextXAlignment = Enum.TextXAlignment.Left

        makeDraggable(PFrame, PTitle)

        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not PFrame or not PFrame.Parent then
                conn:Disconnect()
                return
            end
            local balls = FetchBalls()
            local currentSpeed = 0
            for _, b in ipairs(balls) do
                local zoom = b:FindFirstChild("zoomies")
                if zoom then
                    local spd = zoom.VectorVelocity.Magnitude
                    if spd > currentSpeed then currentSpeed = spd end
                end
            end
            if currentSpeed > ballStatsPeak then ballStatsPeak = currentSpeed end
            VLabel.Text = string.format("Cur: %.1f", currentSpeed)
            PLabel.Text = string.format("Peak: %.1f", ballStatsPeak)
        end)
    else
        if PFrame and PFrame.Parent then
            local parent = PFrame.Parent
            PFrame:Destroy()
            if parent:IsA("ScreenGui") then parent:Destroy() end
        end
        PFrame = nil; VLabel = nil; PLabel = nil; ballStatsPeak = 0
    end
end

