local curveMethod = "camera"
local ACCURACY_FACTOR = 1.285
local basePreClick = 1.4
local maxHorizontalMiss = 5

-- Anti-curve variables
local ballPrevVelocity = {}
local antiCurveData = {}
local CURVE_BOOST_FACTOR = 1.3
local CURVE_ACCEL_THRESHOLD = 60
local SMOOTH_ALPHA = 0.3
local CONSISTENT_FRAMES_NEEDED = 3

-- Parry tracking
local parryTimes = {}
local parryCount = 0
local parryHead = 1

-- Ball states
local ballStates = {}

function InitBallState(ball)
    if ball:GetAttribute("realBall") then
        ballStates[ball] = { parried = false }
        ball:GetAttributeChangedSignal("target"):Connect(function()
            if ballStates[ball] then ballStates[ball].parried = false end
        end)
    end
end

BallsFolder.ChildAdded:Connect(InitBallState)
BallsFolder.ChildRemoved:Connect(function(ball)
    ballStates[ball] = nil
    ballPrevVelocity[ball] = nil
    antiCurveData[ball] = nil
end)
for _, ball in ipairs(BallsFolder:GetChildren()) do InitBallState(ball) end

function ExecuteParry()
    local camCF = camera and camera.CFrame or CFrame.new()
    
    if curveMethod == "upwards" then
        local look = camCF.LookVector
        local upDir = Vector3.new(look.X, 10, look.Z).Unit
        camCF = CFrame.new(camCF.Position, camCF.Position + upDir)
    elseif curveMethod == "backwards" then
        camCF = CFrame.lookAt(camCF.Position, camCF.Position - camCF.LookVector)
    elseif curveMethod == "random" then
        local rd = Vector3.new(math.random(-1000,1000)*0.001, math.random(-350,1000)*0.001, math.random(-1000,1000)*0.001).Unit
        camCF = CFrame.new(camCF.Position, camCF.Position + rd)
    end
    
    if next(ParryRemotes) then
        for remote, args in pairs(ParryRemotes) do
            local modArgs = {args[1], args[2], 0, camCF, args[5], args[6]}
            if remote:IsA("RemoteEvent") then
                remote:FireServer(unpack(modArgs))
            else
                remote:InvokeServer(unpack(modArgs))
            end
        end
    else
        VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end
    
    if ParryAnim then
        pcall(function()
            if type(ParryAnim) == "function" then ParryAnim()
            elseif type(ParryAnim) == "table" and ParryAnim.Play then ParryAnim:Play() end
        end)
    end
    return true
end

function recordAutoParry()
    local now = tick()
    if parryCount < 5 then parryCount = parryCount + 1
    else parryHead = (parryHead % 5) + 1 end
    parryTimes[((parryHead + parryCount - 2) % 5) + 1] = now
end

function countRecent()
    local now = tick()
    local count = 0
    for i = 1, parryCount do
        if now - parryTimes[((parryHead + i - 2) % 5) + 1] < 0.5 then count = count + 1 end
    end
    return count
end

function getAntiCurveMultiplier(ball, playerPos, currentVelocity)
    local prev = ballPrevVelocity[ball]
    if not prev then
        ballPrevVelocity[ball] = currentVelocity
        antiCurveData[ball] = { smoothAx = 0, smoothAy = 0, smoothAz = 0, curveFrames = 0 }
        return 1.0
    end
    
    local ax, ay, az = currentVelocity.X - prev.X, currentVelocity.Y - prev.Y, currentVelocity.Z - prev.Z
    ballPrevVelocity[ball] = currentVelocity
    
    local data = antiCurveData[ball]
    if not data then
        data = { smoothAx = 0, smoothAy = 0, smoothAz = 0, curveFrames = 0 }
        antiCurveData[ball] = data
    end
    
    data.smoothAx = data.smoothAx * (1 - SMOOTH_ALPHA) + ax * SMOOTH_ALPHA
    data.smoothAy = data.smoothAy * (1 - SMOOTH_ALPHA) + ay * SMOOTH_ALPHA
    data.smoothAz = data.smoothAz * (1 - SMOOTH_ALPHA) + az * SMOOTH_ALPHA
    
    local accelMag = math.sqrt(data.smoothAx^2 + data.smoothAy^2 + data.smoothAz^2)
    if accelMag < 0.1 then data.curveFrames = 0; return 1.0 end
    
    local dx, dy, dz = playerPos.X - ball.Position.X, playerPos.Y - ball.Position.Y, playerPos.Z - ball.Position.Z
    local dist = math.sqrt(dx^2 + dy^2 + dz^2)
    if dist < 0.01 then return 1.0 end
    
    local ux, uy, uz = dx/dist, dy/dist, dz/dist
    local radialAccel = data.smoothAx*ux + data.smoothAy*uy + data.smoothAz*uz
    local lateralAccel = math.sqrt(math.max(accelMag^2 - radialAccel^2, 0))
    
    if lateralAccel > CURVE_ACCEL_THRESHOLD and radialAccel > 0 then
        data.curveFrames = data.curveFrames + 1
        if data.curveFrames >= CONSISTENT_FRAMES_NEEDED then
            return 1.0 + (CURVE_BOOST_FACTOR - 1.0) * math.min(lateralAccel / (CURVE_ACCEL_THRESHOLD * 2), 1.0)
        end
    else
        data.curveFrames = 0
    end
    return 1.0
end

