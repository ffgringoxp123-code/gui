-- ===== AUTO SPAM =====
local autoSpamRunning = false
local autoSpamThread = nil
local aggressiveMode = false
local autoSpamEnabled = false

function StartAutoSpam()
    if autoSpamThread then return end
    autoSpamRunning = true
    autoSpamThread = task.spawn(function()
        while autoSpamRunning do
            ExecuteParry()
            task.wait(0.001)
        end
        autoSpamThread = nil
    end)
end

function StopAutoSpam()
    autoSpamRunning = false
    autoSpamThread = nil
end

function checkAutoSpam()
    if not autoSpamEnabled then
        if aggressiveMode then aggressiveMode = false; StopAutoSpam() end
        return
    end
    local recent = countRecent()
    if recent >= 3 and not aggressiveMode then
        aggressiveMode = true
        StartAutoSpam()
    elseif recent < 3 and aggressiveMode then
        aggressiveMode = false
        StopAutoSpam()
    end
end

-- ===== AUTO PARRY =====
local autoParryEnabled = false
local autoParryConnection = nil

function AutoParryLoop()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local pos = root.Position
    local pingMs = statsPingItem:GetValue()
    local pingFactor = math.clamp(pingMs * 0.01, 1, 20)
    
    for _, ball in ipairs(BallsFolder:GetChildren()) do
        if not ball:GetAttribute("realBall") or ball:GetAttribute("target") ~= player.Name then continue end
        
        local state = ballStates[ball]
        if not state then InitBallState(ball); state = ballStates[ball] end
        if state.parried then continue end
        
        local zoomies = ball:FindFirstChild("zoomies")
        if not zoomies then continue end
        
        local vel = zoomies.VectorVelocity
        local vx, vy, vz = vel.X, vel.Y, vel.Z
        local bx, by, bz = ball.Position.X, ball.Position.Y, ball.Position.Z
        local dx, dy, dz = pos.X - bx, pos.Y - by, pos.Z - bz
        local distSq = dx^2 + dy^2 + dz^2
        if distSq < 1 then continue end
        
        local dist = math.sqrt(distSq)
        local approachSpeed = (dx*vx + dy*vy + dz*vz) / dist
        if approachSpeed <= 0 then continue end
        
        local horizSpeedSq = vx^2 + vz^2
        if horizSpeedSq > 0.001 then
            if math.abs(dx*vz - dz*vx) / math.sqrt(horizSpeedSq) > maxHorizontalMiss then continue end
        end
        
        local cappedSpeed = math.min(approachSpeed, 650)
        local parryRadius = pingFactor + math.max(approachSpeed / ((2.4 + cappedSpeed * 0.002) * ACCURACY_FACTOR), 9.5)
        parryRadius = parryRadius * basePreClick * getAntiCurveMultiplier(ball, pos, vel)
        
        if dist <= parryRadius then
            state.parried = true
            ExecuteParry()
            recordAutoParry()
        end
    end
    checkAutoSpam()
end

function SetAutoParryConnection()
    if autoParryConnection then autoParryConnection:Disconnect(); autoParryConnection = nil end
    if autoParryEnabled then autoParryConnection = RunService.Stepped:Connect(AutoParryLoop) end
end

function ToggleAutoParry(on)
    autoParryEnabled = on
    SetAutoParryConnection()
    if not on then StopAutoSpam(); aggressiveMode = false end
end

