----------[ TOGGLE MINIMIZE ]----------

local isMinimized = false
local originalSize = MainFrame.Size

local function ToggleMinimize()
    isMinimized = not isMinimized

    if isMinimized then
        ContentFrame.Visible = false
        Separator.Visible = false

        local targetSize = UDim2.new(0, 260, 0, 42)
        local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        local sizeTween = TweenService:Create(MainFrame, tweenInfo, { Size = targetSize })
        sizeTween:Play()

        ToggleBtn.Image = "rbxassetid://3926307971" -- Arrow up
        MainCorner.CornerRadius = UDim.new(0, 21)
    else
        ContentFrame.Visible = true
        Separator.Visible = true

        local targetSize = originalSize
        local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        local sizeTween = TweenService:Create(MainFrame, tweenInfo, { Size = targetSize })
        sizeTween:Play()

        ToggleBtn.Image = "rbxassetid://3926305904" -- Arrow down
        MainCorner.CornerRadius = UDim.new(0, 14)
    end
end

ToggleBtn.MouseButton1Click:Connect(ToggleMinimize)

----------[ DRAG SCRIPT ]----------

local dragging = false
local dragInput
local dragStart
local startPos

HeaderFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

HeaderFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

