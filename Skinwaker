            toggleCircle.BackgroundColor3 = COLORS.Pink
            toggleCircle:TweenPosition(UDim2.new(0, 2, 0, 2), "Out", "Quad", 0.15, true)
        end
    end

    updateVisual()

    toggleBtn.MouseButton1Click:Connect(function()
        toggled = not toggled
        updateVisual()
        pcall(callback, toggled)
    end)

    return frame
