    descLbl.Font = Enum.Font.Gotham
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.ZIndex = 4
    descLbl.Parent = frame

    local toggleBtn = Instance.new("ImageButton")
    toggleBtn.Name = "ToggleBtn"
    toggleBtn.Size = UDim2.new(0, 36, 0, 20)
    toggleBtn.Position = UDim2.new(1, -44, 0, 14)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 30, 50)
    toggleBtn.BorderSizePixel = 0
    toggleBtn.ClipsDescendants = true
    toggleBtn.ZIndex = 4
    toggleBtn.Parent = frame

    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 10)
    toggleCorner.Parent = toggleBtn

    local toggleCircle = Instance.new("Frame")
    toggleCircle.Name = "Circle"
    toggleCircle.Size = UDim2.new(0, 16, 0, 16)
    toggleCircle.Position = UDim2.new(0, 2, 0, 2)
    toggleCircle.BackgroundColor3 = COLORS.Pink
    toggleCircle.BorderSizePixel = 0
    toggleCircle.ZIndex = 5

    local circleCorner = Instance.new("UICorner")
    circleCorner.CornerRadius = UDim.new(0, 8)
    circleCorner.Parent = toggleCircle

    toggleCircle.Parent = toggleBtn

    local toggled = default

    local function updateVisual()
        if toggled then
            toggleBtn.BackgroundColor3 = COLORS.Pink
            toggleCircle.BackgroundColor3 = COLORS.White
            toggleCircle:TweenPosition(UDim2.new(0, 18, 0, 2), "Out", "Quad", 0.15, true)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 30, 50)
            toggleCircle.BackgroundColor3 = COLORS.Pink
            toggleCircle:TweenPosition(UDim2.new(0, 2, 0, 2), "Out", "Quad", 0.15, true)
        end
    end

    updateVisual()

    toggleBtn.MouseButton1Click:Connect(function()
        toggled = not toggled
        updateVisual()
        pcall(callback, toggled)
    end)

    return frame
end

