    local toggled = default

    local function updateVisual()
        if toggled then
            toggleBtn.BackgroundColor3 = COLORS.Pink
            toggleCircle.BackgroundColor3 = COLORS.White
            toggleCircle:TweenPosition(UDim2.new(0, 16, 0, 2), "Out", "Quad", 0.15, true)
        else
