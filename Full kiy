-- Spam cache
local _remCache = {}
local _argsCache = {}
local _fVec2 = { 0, 0 }
local _fCF = CFrame.new()
local _fCacheT = 0
local _fBuilt = false

local function rebuildSpamCache()
    local now = os.clock()
    if now - _fCacheT < 0.016 then return end
    _fCacheT = now
    local cam = workspace.CurrentCamera
    local ok, mouse = pcall(function() return UI:GetMouseLocation() end)
    _fVec2 = { (mb and not pcMode) and cam.ViewportSize.X / 2 or (ok and mouse.X or cam.ViewportSize.X / 2), (mb and not pcMode) and cam.ViewportSize.Y / 2 or (ok and mouse.Y or cam.ViewportSize.Y / 2) }
    _fCF = riverGetCFrame()
    local ed = {}
    if Alive then
        for _, e in pairs(Alive:GetChildren()) do
            if e.PrimaryPart then
                pcall(function()
                    local sp = cam:WorldToScreenPoint(e.PrimaryPart.Position)
                    ed[e.Name] = sp
                end)
            end
        end
    end
    _argsCache = {}; _remCache = {}
    for rem, args in pairs(revertedRemotes) do
        local mod = { args[1], args[2], args[3], _fCF, ed, _fVec2, args[7] }
        table.insert(_remCache, rem); table.insert(_argsCache, mod)
    end
    _fBuilt = #_remCache > 0
end

local function doFF()
    if not pl.Character or not _fBuilt then return end
    if not Sys.__first_parry_done then
        pcall(function()
            for _, c in pairs(getconnections(pl.PlayerGui.Hotbar.Block.Activated)) do c:Fire() end
        end)
        Sys.__first_parry_done = true
        serverFireCounter = serverFireCounter + 1
        return
    end
    for i = 1, #_remCache do
        local rem = _remCache[i]; local args = _argsCache[i]
        if rem and args then
            pcall(function()
                if rem:IsA("RemoteEvent") then rem:FireServer(table.unpack(args))
                else rem:InvokeServer(table.unpack(args)) end
            end)
        end
    end
    serverFireCounter = serverFireCounter + 1
end

