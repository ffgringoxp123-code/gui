local function isValidArgs(a)
    return #a == 7 and type(a[2]) == "string" and type(a[3]) == "number" and typeof(a[4]) == "CFrame" and type(a[5]) == "table" and type(a[6]) == "table" and type(a[7]) == "boolean"
end

task.spawn(function()
    pcall(function()
        local mt2 = getrawmetatable(game)
        local old2 = mt2.__index
        setreadonly(mt2, false)
        mt2.__index = newcclosure(function(self, key)
            if key == "FireServer" and self:IsA("RemoteEvent") then
                return newcclosure(function(_, ...)
                    local a = { ... }
                    if isValidArgs(a) or self.Name:find("Parry") then
                        revertedRemotes[self] = a
                        if not hasData then hasData = true end
                    end
                    return old2(self, key)(self, ...)
                end)
            end
            return old2(self, key)
        end)
        setreadonly(mt2, true)
    end)
end)

