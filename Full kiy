    label.TextXAlignment = Enum.TextXAlignment.Center
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = billboard
    humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    return label, billboard
end

local function ae_update_label(player, label)
    if not player or not player.Parent or not label or not label.Parent then return false end
    local character = player.Character
    if not character or not character.Parent or not character:FindFirstChildOfClass("Humanoid") then return false end
    if S.AE then
        label.Visible = true
        local ability_name = player:GetAttribute("EquippedAbility")
        label.Text = ability_name and (player.DisplayName .. " [" .. ability_name .. "]") or player.DisplayName
    else
        label.Visible = false
    end
    return true
end

local function ae_setup_character(player)
    if not S.AE then return end
    task.wait(0.1)
    local character = player.Character
    if not character or not character.Parent or not character:FindFirstChildOfClass("Humanoid") then return end
    local label, billboard = ae_create_billboard(player)
    if not label then return end
    if not AE_STATE.players[player] then AE_STATE.players[player] = {} end
    AE_STATE.players[player].label = label
    AE_STATE.players[player].billboard = billboard
    AE_STATE.players[player].character = character
    character.AncestryChanged:Connect(function()
        if not character.Parent then
            if AE_STATE.players[player] then
                if AE_STATE.players[player].billboard then AE_STATE.players[player].billboard:Destroy() end
                AE_STATE.players[player].label = nil
                AE_STATE.players[player].billboard = nil
                AE_STATE.players[player].character = nil
            end
        end
    end)
end

local function ae_remove_player(player)
    if AE_STATE.players[player] then
        if AE_STATE.players[player].billboard then pcall(function() AE_STATE.players[player].billboard:Destroy() end) end
        AE_STATE.players[player] = nil
    end
    AEGUI[player] = nil
end

local function ae_add_player(player)
    if player == pl then return end
    ae_remove_player(player)
    AEGUI[player] = true
    player.CharacterAdded:Connect(function() ae_setup_character(player) end)
    if player.Character then task.spawn(function() ae_setup_character(player) end) end
end

