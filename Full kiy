local function KSS_stop()
    if KSS_curSound then pcall(function() KSS_curSound:Stop(); KSS_curSound:Destroy() end); KSS_curSound = nil end
end

local function KSS_play(pos)
    KSS_stop()
    local part = Instance.new("Part")
    part.Anchored = true; part.CanCollide = false; part.Transparency = 1
    part.Size = Vector3.new(0.1, 0.1, 0.1)
    part.Position = pos or Vector3.new(0, 0, 0)
    part.Parent = workspace
    local snd = Instance.new("Sound")
    snd.SoundId = "rbxassetid://" .. KSS_selected
    snd.Volume = 0.7; snd.RollOffMode = Enum.RollOffMode.Linear; snd.MaxDistance = 500
    snd.Parent = part
    KSS_curSound = snd; snd:Play()
    DB:AddItem(part, 5)
end

local function KSS_hookPlayer(p)
    local function onChar(char)
        local hum = char:WaitForChild("Humanoid", 5)
        if hum then
            hum.Died:Connect(function()
                if p ~= pl then
                    local pos = char.PrimaryPart and char.PrimaryPart.Position or workspace.CurrentCamera.CFrame.Position
                    KSS_play(pos)
                end
            end)
        end
    end
    if p.Character then task.spawn(function() onChar(p.Character) end) end
    p.CharacterAdded:Connect(onChar)
end

local function KSS_enable()
    for _, p in ipairs(P:GetPlayers()) do KSS_hookPlayer(p) end
    KSS_conns.playerAdded = P.PlayerAdded:Connect(function(p) KSS_hookPlayer(p) end)
end

local function KSS_disable()
    KSS_stop()
    for _, c in pairs(KSS_conns) do pcall(function() c:Disconnect() end) end
    KSS_conns = {}
end

R.Heartbeat:Connect(function()
    if S.KS and not KSS_conns.playerAdded then KSS_enable()
    elseif not S.KS and KSS_conns.playerAdded then KSS_disable() end
end)

