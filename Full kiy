-- ===== CONFIG SLOT HELPER =====
local HS2 = game:GetService("HttpService")
local ALL_KEYS = { "AP","AS","AD","SI","IM","PE","DE","RE","BE","BT","VT","AE","KS","HS","NR","NR2","SC","ID","IW","TB","FP","FB","CD","LAP","LAS","AF","BF","SR","TN","AE2","DD","TD","PD","SG" }

local function buildCfg(slotName)
    local cfg = { _name = slotName or "" }
    for _, k in ipairs(ALL_KEYS) do cfg[k] = S[k] end
    cfg.orbitR = orbitR; cfg.orbitH = orbitH; cfg.imOrbitR = imOrbitR
    cfg.swordModel = swordModel; cfg.swordAnimations = swordAnimations; cfg.swordFX = swordFX
    cfg.Speed_Divisor_Multiplier = Speed_Divisor_Multiplier
    cfg.ParryThreshold = ParryThreshold; cfg.savedWS = savedWS; cfg.savedJP = savedJP
    return cfg
end

local function getCfgKey(slot) return "Kittylol_Config_Slot" .. tostring(slot) .. ".json" end

local function saveCfgSlot(slot, name)
    local ok, err = pcall(function()
        writefile(getCfgKey(slot), HS2:JSONEncode(buildCfg(name or "")))
    end)
    return ok
end

local function loadCfgSlot(slot)
    local found, loadedName = false, ""
    pcall(function()
        local key = getCfgKey(slot)
        if not isfile(key) then return end
        local ok, raw = pcall(readfile, key)
        if not ok then return end
        local ok2, cfg = pcall(function() return HS2:JSONDecode(raw) end)
        if not ok2 or not cfg then return end
        loadedName = cfg._name or ""
        for _, k in ipairs(ALL_KEYS) do if cfg[k] ~= nil then S[k] = cfg[k] end end
        if cfg.orbitR then orbitR = cfg.orbitR end
        if cfg.orbitH then orbitH = cfg.orbitH end
        if cfg.imOrbitR then imOrbitR = cfg.imOrbitR end
        if cfg.swordModel then swordModel = cfg.swordModel end
        if cfg.swordAnimations then swordAnimations = cfg.swordAnimations end
        if cfg.swordFX then swordFX = cfg.swordFX end
        if cfg.Speed_Divisor_Multiplier then Speed_Divisor_Multiplier = cfg.Speed_Divisor_Multiplier end
        if cfg.ParryThreshold then ParryThreshold = cfg.ParryThreshold end
        if cfg.savedWS then savedWS = cfg.savedWS end
        if cfg.savedJP then savedJP = cfg.savedJP end
        found = true
    end)
    return found, loadedName
end

local function deleteCfgSlot(slot)
    pcall(function()
        if isfile(getCfgKey(slot)) then delfile(getCfgKey(slot)) end
    end)
end

