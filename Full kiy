                table.insert(uuids, v)
            end
        end
        local info = rawget(t2, 3)
        if not info then return end
        local selector = rawget(info, 3)
        local uuid = uuids[selector]
        local hash = rawget(info, 2)
        if not uuid or not hash then return end
        local remoteyield = Instance.new("BindableEvent")
        local waxfs = (game:FindFirstChildWhichIsA("RemoteEvent", true) or Instance.new("RemoteEvent")).FireServer
