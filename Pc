local function linearPredict(a, b, t) return a + (b - a) * t end

local function isCurvedMixed()
    local ball = nil
    if Balls then for _, v in ipairs(Balls:GetChildren()) do if v:GetAttribute("realBall") then ball = v; break end end end
    if not ball then return false end
    local zoomies = ball:FindFirstChild("zoomies"); if not zoomies then return false end
    local currentVel = zoomies.VectorVelocity; table.insert(recentVels, currentVel)
    if #recentVels > 4 then table.remove(recentVels, 1) end
    local speed = currentVel.Magnitude; if speed < 1 or speed > 9000 then return false end
    local avgVel = currentVel
    if #recentVels > 1 then local sum = Vector3.zero; for _, v in ipairs(recentVels) do sum = sum + v end; avgVel = sum / #recentVels end
    local ballDir = avgVel.Unit; local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return false end
    local pos = char.PrimaryPart.Position; local direction = (pos - ball.Position).Unit; local dot = direction:Dot(ballDir)
    if dot >= 0.95 then return false end
    local pingRaw = Stats.Network.ServerStatsItem["Data Ping"]:GetValue(); local pingS = pingRaw / 1000
    local distance = (pos - ball.Position).Magnitude; local reachTime = distance / speed - pingS
    local speedThreshold = math.min(speed / 100, 45); local ballDistThreshold = 15 - math.min(distance / 1000, 15) + speedThreshold
    if speed > 100 and reachTime > pingRaw / 10 then ballDistThreshold = math.max(ballDistThreshold - 15, 15) end
    if distance < ballDistThreshold * 0.85 then return false end
    local dirDiff = (ballDir - avgVel).Unit; local dirSim = direction:Dot(dirDiff); local dotDiff = dot - dirSim
    local dotThresholdRiver = math.clamp(0.55 - (pingS * 0.75), -1, 0.45); local dotThresholdAllusive = 0.5 - pingS
    local dotThreshold = dotThresholdRiver * 0.55 + dotThresholdAllusive * 0.45; local visualThresh = 0.12
    if avgVel.Magnitude > 150 then visualThresh = visualThresh - 0.02 end
    if dotDiff < math.min(dotThreshold, visualThresh) then lastStableTime = tick(); return true end
    local clampedDot = math.clamp(dot, -1, 1); local radiansRiver = math.asin(clampedDot); local radiansAllusive = math.rad(math.asin(clampedDot))
    local blendedRadians = radiansRiver * 0.6 + radiansAllusive * 0.4
    det.__lerp_radians = linearPredict(det.__lerp_radians, blendedRadians, 0.83); smoothRadians = linearPredict(smoothRadians, radiansAllusive, 0.85)
    if det.__lerp_radians < 0.017 then det.__last_warping = tick() end; if smoothRadians < 0.015 then lastStableTime = tick() end
    if (tick() - lastStableTime) < 0.07 then return true end; if (tick() - det.__last_warping) < (reachTime / 1.45) then return true end
    if (tick() - det.__curving) < (reachTime / 1.2) then return true end
    if #recentVels == 4 then
        local iDiff1 = (ballDir - recentVels[1].Unit).Unit; local d1 = dot - direction:Dot(iDiff1)
        local iDiff2 = (ballDir - recentVels[2].Unit).Unit; local d2 = dot - direction:Dot(iDiff2)
        if d1 < visualThresh or d2 < visualThresh then return true end
    end
    return dot < dotThreshold
end

