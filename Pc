    local events = {}
    if workspace:FindFirstChild("Alive") then
        for _, v in ipairs(workspace.Alive:GetChildren()) do
            if v ~= char and v.PrimaryPart then
                local screenPos, isOnScreen = cam:WorldToScreenPoint(v.PrimaryPart.Position)
                if isOnScreen then
                    events[tostring(v)] = screenPos
                end
            end
        end
    end
    c[3] = camCF.LookVector
    c[4] = camCF
    c[5] = events
    c[6] = mousePos
    pcall(function()
        f_raw(remote, unpack(c))
    end)
end

